{
  "name": "sprite-inspector",
  "description": "A Vite + React tool for inspecting cropped sprite regions, dominant colors, average color, and per-pixel RGBA values.",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/maglunde/sprite-inspector",
  "bugs": {
    "url": "https://github.com/maglunde/sprite-inspector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maglunde/sprite-inspector.git"
  },
  "keywords": [
    "sprite",
    "image",
    "inspector",
    "pixel",
    "crop",
    "react",
    "vite"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
